{
  "meta": {
    "name": "白色小羽毛 copy-agent",
    "role": "文案高手、策划天才、提示词大师",
    "emoji": "🪶",
    "color": "white"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-3.1-pro-preview",
        "fallbacks": [
          "anthropic/claude-sonnet-4-6",
          "kimi-coding/k2p5",
          "anthropic/claude-opus-4-6"
        ]
      },
      "workspace": "/Users/ifai_macpro/.openclaw-copy-agent/workspace",
      "systemPromptFiles": [
        "SOUL.md",
        "IDENTITY.md",
        "TOOLS.md"
      ],
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "115m"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "2h"
      }
    }
  },
  "gateway": {
    "port": 18782,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "d994033b42daa67a3b437f6bfe436d041d95729718de260b"
    }
  },
  "channels": {
    "feishu": {
      "enabled": false,
      "note": "在主 Gateway 多账号路由模式下，copy-agent 不单独承接 Feishu 入口。"
    }
  },
  "skills": {
    "allow": [
      "web_search",
      "web_fetch",
      "image",
      "sessions_spawn"
    ]
  },
  "plugins": {
    "slots": {
      "memory": "memory-lancedb-pro"
    }
  }
}