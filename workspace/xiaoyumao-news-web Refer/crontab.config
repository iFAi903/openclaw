# =============================================================================
# 小羽毛 AI 新闻早报 - Crontab 配置
# 添加方法: crontab -e 然后把下面这行添加到文件末尾
# =============================================================================

# 每日 07:00 执行新闻更新（Asia/Taipei 时区）
# 注意：需要确保 PATH 包含 node、npm、python3

SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:$HOME/.npm-global/bin
HOME=/Users/ifai_macpro

# 每天 7:00 执行新闻早报更新
0 7 * * * /Users/ifai_macpro/.openclaw/workspace/iFAi/workspace/xiaoyumao-news-web\ Refer/daily-cron.sh >> /tmp/xiaoyumao-news-cron.log 2>&1

# =============================================================================
# 安装步骤：
# 1. 复制上面那行 cron 任务（去掉 # 注释）
# 2. 运行: crontab -e
# 3. 粘贴并保存
# 4. 验证: crontab -l
# 5. 查看日志: tail -f /tmp/xiaoyumao-news-cron.log
# =============================================================================
